import Layout from '../layouts/BlogPost.astro';
---

<Layout
	title="About"
	description="Andrew Xie (谢杨浩) — an engineer writing about software, systems, and the things he builds on the side."
	pubDate={new Date('July 10 2026')}
	heroImage={AboutHeroImage}
>
	<p>
		I'm Andrew Xie (谢杨浩), an engineer who likes building things and then figuring out why they
		broke. This is my corner of the internet — a slow, quiet journal for notes that outlast a
		tweet.
	</p>

	<p>
		I write mostly about the unglamorous middle of projects: the small decisions that turn "wouldn't
		it be cool if" into something that actually works. Lately that's meant a fair amount of AI and
		machine learning, a mahjong hand-recognition engine, and a lot of thinking about how to ship
		faster without shipping worse.
	</p>

	<p>
		This site is built with <a href="https://astro.build/">Astro</a>, styled by hand, and deployed
		on Vercel — the whole thing designed to be boring and automatic so I can spend my attention on
		writing instead of maintenance.
	</p>

	<p>
		You can find me on <a href="https://github.com/scv057">GitHub</a>, drop me a line by
		<a href="mailto:xie5997231@gmail.com">email</a>, or subscribe via the
		<a href="/rss.xml">RSS feed</a>. No schedule, no noise — just new posts when they're ready.
	</p>
</Layout>
