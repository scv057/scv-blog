---
import { type CollectionEntry, render } from 'astro:content';
import BlogPost from '../../../layouts/BlogPost.astro';
import type { PostRef } from '../../../components/PostNav.astro';
import { getPosts } from '../../../lib/posts';

export async function getStaticPaths() {
	const posts = await getPosts('zh');
	return posts.map((post, i) => ({
		params: { slug: post.id },
		props: {
			post,
			newer: i > 0 ? { id: posts[i - 1].id, title: posts[i - 1].data.title } : null,
			older: i < posts.length - 1 ? { id: posts[i + 1].id, title: posts[i + 1].data.title } : null,
		},
	}));
}
type Props = {
	post: CollectionEntry<'blog'>;
	newer: PostRef | null;
	older: PostRef | null;
};

const { post, newer, older } = Astro.props;
const { Content, headings } = await render(post);

const words = (post.body ?? '').trim().split(/\s+/).filter(Boolean).length;
const minutes = Math.max(1, Math.round(words / 200));
---

<BlogPost {...post.data} minutes={minutes} older={older} newer={newer} headings={headings}>
	<Content />
</BlogPost>
