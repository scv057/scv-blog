---
import FormattedDate from './FormattedDate.astro';
import { useTranslations, localizedPath, categoryLabel, type Lang } from '../i18n/utils';
import type { Category } from '../consts';
import { getPosts } from '../lib/posts';

interface Props {
	/** When set, only show posts in this category (topic archive mode). */
	category?: Category;
}

const { category } = Astro.props;
const lang = (Astro.currentLocale ?? 'en') as Lang;
const t = useTranslations(lang);

const posts = await getPosts(lang, category);
---

<main class="wrap">
	<div class="masthead">
		<div class="eyebrow">
			<span class="mono">{category ? t('topics.eyebrow') : t('blog.archive')}</span>
			<span class="mono">{posts.length} {t('blog.entries')}</span>
		</div>
		<h1>{category ? `${categoryLabel(lang, category)}${lang === 'zh' ? '。' : '.'}` : t('blog.title')}</h1>
		<hr class="rule-double" />
	</div>

	<section style="padding-bottom: clamp(3rem, 6vw, 5rem);">
		{
			posts.length > 0 ? (
				<ul class="index">
					{posts.map((post) => (
						<li>
							<a class="entry" href={localizedPath(lang, `blog/${post.id}`)}>
								<span class="date">
									<FormattedDate date={post.data.pubDate} />
								</span>
								<h3>{post.data.title}</h3>
								<span class="tag">{categoryLabel(lang, post.data.category)}</span>
								<span class="dek">{post.data.description}</span>
							</a>
						</li>
					))}
				</ul>
			) : (
				<p class="empty-note">{t('blog.empty')}</p>
			)
		}
	</section>
</main>
