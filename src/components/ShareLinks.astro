const platforms =
	lang === 'zh'
		? [
				{ name: '微博', icon: 'weibo', href: `https://service.weibo.com/share/share.php?url=${eUrl}&title=${eTitle}` },
				{ name: 'X', icon: 'x', href: `https://twitter.com/intent/tweet?text=${eTitle}&url=${eUrl}` },
				{ name: 'Telegram', icon: 'telegram', href: `https://t.me/share/url?url=${eUrl}&text=${eTitle}` },
			]
		: [
				{ name: 'X', icon: 'x', href: `https://twitter.com/intent/tweet?text=${eTitle}&url=${eUrl}` },
				{ name: 'Hacker News', icon: 'hn', href: `https://news.ycombinator.com/submitlink?u=${eUrl}&t=${eTitle}` },
				{ name: 'LinkedIn', icon: 'linkedin', href: `https://www.linkedin.com/sharing/share-offsite/?url=${eUrl}` },
				{ name: 'Telegram', icon: 'telegram', href: `https://t.me/share/url?url=${eUrl}&text=${eTitle}` },
			];

// Build-time QR for WeChat (Chinese posts only): scan inside WeChat, then forward
const wechatQr =
	lang === 'zh'
		? await QRCode.toString(url, { type: 'svg', margin: 1, width: 148, color: { dark: '#1b1917', light: '#0000' } })
		: null;
---

<div class="share" data-url={url} data-title={title}>
	<div class="share-kicker"><span class="mono">{t('share.label')}</span></div>
	<div class="share-row">
		<button
			type="button"
			class="share-chip"
			data-share-copy
			aria-label={t('share.copy')}
			title={t('share.copy')}
			data-copied-label={t('share.copied')}
		>
			<svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d={icons.copy} /></svg>
			<svg viewBox="0 0 24 24" aria-hidden="true" data-check hidden
				><path fill="currentColor" d={icons.check} /></svg
			>
		</button>
		<button
			type="button"
			class="share-chip"
			data-share-native
			aria-label={t('share.native')}
			title={t('share.native')}
			hidden
		>
			<svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d={icons.native} /></svg>
		</button>
		{
			platforms.map((p) => (
				<a class="share-chip" href={p.href} target="_blank" rel="noopener" aria-label={p.name} title={p.name}>
					<svg viewBox="0 0 24 24" aria-hidden="true">
						<path fill="currentColor" d={icons[p.icon]} />
					</svg>
				</a>
			))
		}
		{
			wechatQr && (
				<span class="share-wechat">
					<button type="button" class="share-chip" aria-label={t('share.wechat')} title={t('share.wechat')} aria-describedby="wechat-qr">
						<svg viewBox="0 0 24 24" aria-hidden="true">
							<path fill="currentColor" d={icons.wechat} />
						</svg>
					</button>
					<div class="share-qr" id="wechat-qr" role="tooltip">
						<Fragment set:html={wechatQr} />
						<p>{t('share.wechatHint')}</p>
					</div>
				</span>
			)
		}
	</div>
</div>

<script>
	function init() {
		document.querySelectorAll<HTMLElement>('.share').forEach((root) => {
			const url = root.dataset.url ?? location.href;
			const title = root.dataset.title ?? document.title;

			const copyBtn = root.querySelector<HTMLButtonElement>('[data-share-copy]');
			if (copyBtn && !copyBtn.dataset.bound) {
				copyBtn.dataset.bound = '1';
				const [linkIcon, checkIcon] = copyBtn.querySelectorAll('svg');
				const label = copyBtn.getAttribute('aria-label') ?? '';
				copyBtn.addEventListener('click', async () => {
					try {
						await navigator.clipboard.writeText(url);
						linkIcon.setAttribute('hidden', '');
						checkIcon.removeAttribute('hidden');
						copyBtn.classList.add('copied');
						copyBtn.title = copyBtn.dataset.copiedLabel ?? '';
						setTimeout(() => {
							checkIcon.setAttribute('hidden', '');
							linkIcon.removeAttribute('hidden');
							copyBtn.classList.remove('copied');
							copyBtn.title = label;
						}, 1800);
					} catch {}
				});
			}

			const nativeBtn = root.querySelector<HTMLButtonElement>('[data-share-native]');
			if (nativeBtn && 'share' in navigator) {
				nativeBtn.hidden = false;
				if (!nativeBtn.dataset.bound) {
					nativeBtn.dataset.bound = '1';
					nativeBtn.addEventListener('click', () => navigator.share({ title, url }).catch(() => {}));
				}
			}
		});
	}
	init();
</script>
