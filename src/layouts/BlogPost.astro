---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import Base from './Base.astro';
import FormattedDate from '../components/FormattedDate.astro';
import ShareLinks from '../components/ShareLinks.astro';
import Comments from '../components/Comments.astro';
import PostNav, { type PostRef } from '../components/PostNav.astro';
import { useTranslations, localizedPath, categoryLabel, type Lang } from '../i18n/utils';

type PostData = CollectionEntry<'blog'>['data'];
// lang/category/draft are optional so non-collection pages (e.g. About) can use this layout
type Props = Omit<PostData, 'lang' | 'category' | 'draft'> &
	Partial<Pick<PostData, 'lang' | 'category' | 'draft'>> & {
		minutes?: number;
		older?: PostRef | null;
		newer?: PostRef | null;
		headings?: MarkdownHeading[];
	};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	minutes,
	category,
	older,
	newer,
	headings = [],
} = Astro.props;
const lang = (Astro.currentLocale ?? 'en') as Lang;
const t = useTranslations(lang);

// Only offer a TOC when there is enough structure to navigate
const toc = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
const showToc = toc.length >= 3;
---

<Base title={title} description={description} image={heroImage}>
	<div class="read-progress" aria-hidden="true"></div>
	<main class="wrap article">
		<article data-pagefind-body>
			<header class="article-head">
				<p class="eyebrow mono">
					{t('article.eyebrow')}
					{
						category && (
							<>
								{' · '}
								<a href={localizedPath(lang, `topics/${category}`)}>
									{categoryLabel(lang, category)}
								</a>
							</>
						)
					}
				</p>
				<h1>{title}</h1>
				{description && <p class="standfirst">{description}</p>}
				<div class="byline">
					<FormattedDate date={pubDate} />
					{minutes && (
						<>
							<span class="dot"></span>
							<span>{minutes} {t('byline.minRead')}</span>
						</>
					)}
					{
						updatedDate && (
							<>
								<span class="dot"></span>
								<span class="updated">{t('byline.updated')} <FormattedDate date={updatedDate} /></span>
							</>
						)
					}
				</div>
			</header>

			{heroImage && <Image class="hero" width={1200} height={600} src={heroImage} alt="" />}

			{
				showToc && (
					<nav class="toc" aria-label={t('toc.label')}>
						<span class="mono">{t('toc.label')}</span>
						<ol>
							{toc.map((h) => (
								<li class={`toc-d${h.depth}`}>
									<a href={`#${h.slug}`}>{h.text}</a>
								</li>
							))}
						</ol>
					</nav>
				)
			}

			<div class="prose" data-article-body>
				<slot />
			</div>

			<div class="prose">
				<ShareLinks title={title} />
				<PostNav older={older} newer={newer} />
				<Comments />
			</div>
		</article>
	</main>

	<script is:inline>
		(function () {
			var bar = document.querySelector('.read-progress');
			var body = document.querySelector('[data-article-body]');
			if (!bar || !body) return;
			var ticking = false;
			function update() {
				ticking = false;
				// 100% when the bottom of the article body reaches the viewport bottom
				// (share bar / comments / footer below it don't count as reading)
				var top = body.getBoundingClientRect().top + window.scrollY;
				var end = top + body.offsetHeight - window.innerHeight;
				var p = end > 0 ? Math.min(1, Math.max(0, window.scrollY / end)) : 1;
				bar.style.transform = 'scaleX(' + p + ')';
			}
			function schedule() {
				if (!ticking) {
					ticking = true;
					requestAnimationFrame(update);
				}
			}
			window.addEventListener('scroll', schedule, { passive: true });
			window.addEventListener('resize', schedule, { passive: true });
			update();
		})();
	</script>
</Base>
