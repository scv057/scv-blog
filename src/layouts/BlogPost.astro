---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import Base from './Base.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { useTranslations, localizedPath, categoryLabel, type Lang } from '../i18n/utils';

type Props = CollectionEntry<'blog'>['data'] & { minutes?: number };

const { title, description, pubDate, updatedDate, heroImage, minutes, category } = Astro.props;
const lang = (Astro.currentLocale ?? 'en') as Lang;
const t = useTranslations(lang);
---

<Base title={title} description={description} image={heroImage}>
	<main class="wrap article">
		<article>
			<header class="article-head">
				<p class="eyebrow mono">
					{t('article.eyebrow')}
					{
						category && (
							<>
								{' · '}
								<a href={localizedPath(lang, `topics/${category}`)}>
									{categoryLabel(lang, category)}
								</a>
							</>
						)
					}
				</p>
				<h1>{title}</h1>
				{description && <p class="standfirst">{description}</p>}
				<div class="byline">
					<FormattedDate date={pubDate} />
					{minutes && (
						<>
							<span class="dot"></span>
							<span>{minutes} {t('byline.minRead')}</span>
						</>
					)}
					{
						updatedDate && (
							<>
								<span class="dot"></span>
								<span class="updated">{t('byline.updated')} <FormattedDate date={updatedDate} /></span>
							</>
						)
					}
				</div>
			</header>

			{heroImage && <Image class="hero" width={1200} height={600} src={heroImage} alt="" />}

			<div class="prose">
				<slot />
			</div>
		</article>
	</main>
</Base>
